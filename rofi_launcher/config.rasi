// https://github.com/joepigott/dots/tree/cyberpunk/rofi
configuration {
  display-drun: "";
  display-window: "Windows: ";
  drun-display-format: "{name}";
  modi: "window,run,drun";
  //font: "TerminessNerdFont Bold 32";
  show-icons: false;
}

@theme "/dev/null"

* {
  red      : #de524a;
  lred     : #ff7162;
  green    : #22d87a;
  lgreen   : #c9ee5e;
  yellow   : #ecc747;
  lyellow  : #edd682;
  blue     : #2366c3;
  lblue    : #7fb4ff;
  magenta  : #9132e8;
  lmagenta : #c17fff;
  cyan     : #55e7f0;
  lcyan    : #a7ecef;

  white    : #e5e9e6;
  black    : #130912;

  bg: @black;
  fg: @lgreen;

  disabled : #5d5d5d;

  background-color: transparent;
  color: @lgreen;

  margin: 0;
  padding: 0;
  spacing: 0;
}

window {
    width: 100%;
    height: 100%;
    transparency: "real";
    background-color: #130912bb;
}

mainbox {
    location: center;
    anchor: center;
    margin: 200;
    border: 2;
    border-color: @lgreen;
    orientation: horizontal;
    children: [ "imagebox", "listbox" ];
}

imagebox {
    orientation: vertical;
    expand: false;
    width: 35%;
    children: [ "textbox-dummy1", "clock", "textbox-nettech" ];
}

textbox-dummy1 {
    expand: false;
    margin: 30 0 10 0;
}

clock {
    expand: false;
    padding: 25;
    border: 2 0 2 0;
    border-color: @lgreen;
    orientation: horizontal;
    background-color: #c9ff5e33;
    children: [ "textbox-label", "textbox-number" ];
}

textbox-label {
    expand: true;
    content: "ENTRY TIME REMAINING";
    padding: 10 0 10 0;
}

textbox-number {
    expand: false;
    content: "N/A";
    border: 2;
    border-color: @lgreen;
    padding: 10 30 10 30;
}

textbox-nettech {
    expand: true;
    margin: 50;
    content: "‚Ėą‚Ėą  ‚Ėą ‚Ėą‚Ėą‚Ėą ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėą ‚Ėą   ‚Ėą\n‚Ėą‚Ėą‚Ėą ‚Ėą ‚Ėą     ‚Ėą‚Ėą           ‚Ėą‚Ėą   ‚Ėą    ‚Ėą   ‚Ėą\n‚Ėą ‚Ėą‚Ėą‚Ėą ‚Ėą‚Ėą‚Ėą   ‚Ėą‚Ėą ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą ‚Ėą‚Ėą   ‚Ėą    ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą\n‚Ėą  ‚Ėą‚Ėą ‚Ėą     ‚Ėą‚Ėą           ‚Ėą‚Ėą   ‚Ėą    ‚Ėą   ‚Ėą\n‚Ėą   ‚Ėą ‚Ėą‚Ėą‚Ėą   ‚Ėą‚Ėą ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą ‚Ėą‚Ėą    ‚Ėą‚Ėą‚Ėą ‚Ėą   ‚Ėą\n\n‚Ėą ‚Ėą ‚ĖĆ‚ĖŹ‚ĖŹ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėö‚Ėö‚Ėö‚ĖŹ‚ĖŹ‚Ėä‚Ėä ‚Ėä ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėö ‚ĖĆ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą\n‚Ėą ‚Ėą ‚ĖĆ‚ĖŹ‚ĖŹ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėö‚Ėö‚Ėö‚ĖŹ‚ĖŹ‚Ėä‚Ėä ‚Ėä ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėö ‚ĖĆ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą\n‚Ėą ‚Ėą ‚ĖĆ‚ĖŹ‚ĖŹ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėö‚Ėö‚Ėö‚ĖŹ‚ĖŹ‚Ėä‚Ėä ‚Ėä ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėö ‚ĖĆ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą\n‚Ėą ‚Ėą ‚ĖĆ‚ĖŹ‚ĖŹ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėö‚Ėö‚Ėö‚ĖŹ‚ĖŹ‚Ėä‚Ėä ‚Ėä ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėö ‚ĖĆ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą\n‚Ėą ‚Ėą ‚ĖĆ‚ĖŹ‚ĖŹ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėö‚Ėö‚Ėö‚ĖŹ‚ĖŹ‚Ėä‚Ėä ‚Ėä ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėö ‚ĖĆ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą\n‚Ėą ‚Ėą ‚ĖĆ‚ĖŹ‚ĖŹ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėö‚Ėö‚Ėö‚ĖŹ‚ĖŹ‚Ėä‚Ėä ‚Ėä ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėö ‚ĖĆ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą\n‚Ėą ‚Ėą ‚ĖĆ‚ĖŹ‚ĖŹ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėö‚Ėö‚Ėö‚ĖŹ‚ĖŹ‚Ėä‚Ėä ‚Ėä ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėö ‚ĖĆ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą\n‚Ėą ‚Ėą ‚ĖĆ‚ĖŹ‚ĖŹ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėö‚Ėö‚Ėö‚ĖŹ‚ĖŹ‚Ėä‚Ėä ‚Ėä ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėö ‚ĖĆ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą\n‚Ėą ‚Ėą ‚ĖĆ‚ĖŹ‚ĖŹ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėö‚Ėö‚Ėö‚ĖŹ‚ĖŹ‚Ėä‚Ėä ‚Ėä ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėö ‚ĖĆ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą\n‚Ėą ‚Ėą ‚ĖĆ‚ĖŹ‚ĖŹ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚Ėö‚Ėö‚Ėö‚ĖŹ‚ĖŹ‚Ėä‚Ėä ‚Ėä ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėö ‚ĖĆ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą";
}

listbox {
    orientation: vertical;
    expand: false;
    width: 65%;
    children: [ "textbox-title", "inputbar-wrapper", "listview-wrapper" ];
}

textbox-title {
    expand: false;
    content: "PROTOCOL 6528-A44-X";
    margin: 30 0 10 20;
}

inputbar-wrapper {
    border: 2 0 2 0;
    border-color: @lgreen;
    background-color: #c9ff5e33;
    expand: false;
    children: [ "inputbar" ];
}

inputbar {
    border: 2;
    padding: 25;
    margin: 10 30 10 30;
    border-color: @lgreen;
    background-color: @bg;
}

listview-wrapper {
    children: [ "listview-label", "listview" ];
}

listview-label {
    expand: false;
    orientation: horizontal;
    margin: 25 25 0 25;
    padding: 8 8 8 30;
    border: 2 2 0 2;
    border-color: @lgreen;
    children: [ "textbox-listview-icon", "textbox-listview-label" ];
}

textbox-listview-icon {
    expand: false;
    content: "ůĪáĮ";
    //font: "TerminessNerdFont Bold 48";
    margin: 0 15 0 0;
}

textbox-listview-label {
    expand: false;
    padding: 10;
    content: "TERMINAL BOOTED SUCCESSFULLY... \nPROCEED";
}

listview {
    margin: 0 25 74 25;
    padding: 0;
    border: 2;
    border-color: @lgreen;
}

element {
    padding: 20 20 20 40;
}

element.normal {
    background-color: transparent;
}

element.selected {
    background-color: #c9ff5e33;
}

element-text.selected {
    text-color: @cyan;
}

